# ── Deployment ──
# APP_ENV=production turns OFF the demo auth bypass and drops localhost CORS.
APP_ENV=development
# Force-enable/disable the demo auth bypass (defaults: on in dev, off in prod).
# ALLOW_DEMO_AUTH=false
# Extra allowed CORS origins (comma-separated), in addition to FRONTEND_URL.
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# ── Supabase (server-side JWT verification) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FRONTEND_URL=http://localhost:5173

# ── LLM provider ──
# The agent nodes use Google Gemini via langchain-google-genai. Without this key
# the graph still runs using deterministic fallbacks. The chain tries several
# models (per-model daily quotas) — override the order with GEMINI_MODELS.
GOOGLE_API_KEY=your-google-api-key
# GEMINI_MODELS=gemini-2.5-flash,gemini-flash-latest,gemini-2.5-flash-lite

# ── LangSmith tracing (optional) ──
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=ece-copilot
